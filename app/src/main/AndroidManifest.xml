<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Rete: parlare con quickstore-server (modulo auth/sync) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Trasferimento foto in background (sync/ImageTransferWorker): notifica di
         avanzamento + foreground service tipizzato "dataSync", richiesto da API 34+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Camera Permission -->
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- Storage permissions (per salvare immagini) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Permesso dichiarato da QuickStore: solo app firmate con lo stesso certificato possono leggere il catalogo -->
    <permission
        android:name="net.calvuz.qstore.permission.READ_ARTICLES"
        android:protectionLevel="signature" />

    <application
        android:name=".QuickStoreApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuickStore">

        <activity
            android:name=".app.presentation.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.QuickStore">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>


        <!-- Picker: selettore articoli lanciato da QReport via ActivityResultLauncher -->
        <activity
            android:name=".picker.ArticlePickerActivity"
            android:exported="true"
            android:theme="@style/Theme.QuickStore">
            <intent-filter>
                <action android:name="net.calvuz.qstore.action.PICK_ARTICLES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- ContentProvider catalogo articoli per QReport -->
        <provider
            android:name=".provider.QStoreArticleProvider"
            android:authorities="net.calvuz.qstore.provider"
            android:exported="true"
            android:readPermission="net.calvuz.qstore.permission.READ_ARTICLES" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Disabilita l'auto-init di default di WorkManager: QuickStoreApplication
             implementa Configuration.Provider per iniettare HiltWorkerFactory, le due
             cose non possono coesistere. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Il servizio interno di WorkManager che ospita i worker in foreground (usato da
             ImageTransferWorker) di default non dichiara alcun foregroundServiceType nel
             suo manifest — su API 34+ questo fa fallire setForeground() con
             IllegalArgumentException perché il tipo richiesto dal worker (dataSync) non è
             un sottoinsieme di quello dichiarato (nessuno). Va sovrascritto qui. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

    </application>
</manifest>